# Reddit API credentials (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=ColloationData/1.0 (by /u/your_username)

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
TOGETHER_API_KEY=...

# Custom LLM endpoints (留空则用各厂商默认地址)
# 支持 API 代理、聚合 API (如 openrouter/litellm)、本地 vLLM/ollama 等
JUROR_B_BASE_URL=          # Juror B 自定义地址 (OpenAI 兼容格式)
JUROR_B_API_KEY=            # Juror B 自定义密钥 (留空则用提供商默认 key)
JUROR_C_BASE_URL=          # Juror C 自定义地址
JUROR_C_API_KEY=            # Juror C 自定义密钥

# 绕过系统代理（国内直连 API 代理时，开代理反而连不上）
# JUROR_B_NO_PROXY=true
# JUROR_C_NO_PROXY=true

# Data storage
DATA_DIR=./data

# Proxy (optional, for accessing geo-blocked sites)
# Supports HTTP and SOCKS5 proxies
# PROXY_URL=http://127.0.0.1:7890
# PROXY_URL=socks5://127.0.0.1:1080
